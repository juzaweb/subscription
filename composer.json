{
    "name": "juzaweb/subscription",
    "description": "Subscription payment support",
    "type": "juzaweb-module",
    "homepage": "https://juzaweb.com/cms",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0",
        "juzaweb/core": "^5.0",
        "laravel/pint": "^1.29",
        "srmklive/paypal": "~3.0",
        "juzaweb/api": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Juzaweb\\Modules\\Subscription\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Juzaweb\\Modules\\Subscription\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
